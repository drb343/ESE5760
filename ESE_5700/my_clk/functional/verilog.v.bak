//Verilog HDL for "ESE_5700", "my_clk" "functional"

`resetall
`celldefine
`delay_mode_path
`timescale 1ns/10ps
module my_clk (output wire CLK1, output wire CLK2, input wire CLKin);
	wire x, y, z;
	my_inv my_inv0(z, CLKin);
	my_nor my_nor0(x, CLKin, y);
	buf buf0(CLK1, x);
	my_nor my_nor1(y, z, x);
	buf buf1(CLK2, y);
endmodule
`endcelldefine